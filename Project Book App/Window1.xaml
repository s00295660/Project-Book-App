<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_Book_App"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="Project_Book_App.Window1"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow" Loaded="Window_Loaded">
    <Grid Margin="0,0,0,1">
        <Grid.Background>
            <ImageBrush ImageSource="/search.jpg"/>
        </Grid.Background>
        <ListBox HorizontalAlignment="Left" Height="223" Margin="48,158,0,0" VerticalAlignment="Top" Width="259" d:ItemsSource="{d:SampleData ItemCount=5}" Background="#FF482C2C" Foreground="White" BorderBrush="#FF292929" Opacity="0.93"/>
        <ComboBox x:Name="Genres" HorizontalAlignment="Left" Height="35" Margin="48,92,0,0" VerticalAlignment="Top" Width="113" Background="White" RenderTransformOrigin="0.619,0.529" SelectionChanged="Genres_SelectionChanged" />
        <ComboBox x:Name="Authors" HorizontalAlignment="Left" Height="35" Margin="194,92,0,0" VerticalAlignment="Top" Width="113" Background="White"/>
        <TextBlock HorizontalAlignment="Left" Height="81" Margin="356,300,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="423" Background="White" FontSize="18"><Run Language="en-ie" Text="Desciption :"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Height="37" Margin="356,183,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="208" Background="White" Opacity="0.725" FontSize="20"><Run Language="en-ie" Text="Title"/><LineBreak/><Run Language="en-ie"/></TextBlock>
        <Label Content="Genres" HorizontalAlignment="Left" Height="28" Margin="71,45,0,0" VerticalAlignment="Top" Width="67" Background="WhiteSmoke" Foreground="#E5000000" FontSize="22" FontFamily="Blackadder ITC" Padding="5,0,4,4"/>
        <Label Content="Authors" HorizontalAlignment="Left" Height="28" Margin="212,45,0,0" VerticalAlignment="Top" Width="77" Background="White" Foreground="#E5000000" FontSize="22" FontFamily="Blackadder ITC" Padding="6,1,4,4"/>
        <Button x:Name="Back" Content="Back" HorizontalAlignment="Left" Height="30" Margin="10,10,0,0" VerticalAlignment="Top" Width="69" Click="Back_Click" Background="#FF54001B" BorderBrush="Black" FontFamily="Blackadder ITC" FontSize="18" Foreground="White"/>
        <Button x:Name="AddToWishList" Content="Add" HorizontalAlignment="Left" Height="30" Margin="400,119,0,0" VerticalAlignment="Top" Width="101" Background="Black" BorderBrush="#FFEFEFEF" Click="AddToWishList_Click" Foreground="White" FontFamily="Blackadder ITC" FontSize="18"/>
        <Label Content="Grade" HorizontalAlignment="Left" Height="30" Margin="356,247,0,0" VerticalAlignment="Top" Width="63" Background="White" Foreground="#E5000000" FontSize="24" FontFamily="Blackadder ITC" Padding="5,0,4,4"/>
        <Rectangle HorizontalAlignment="Left" Height="30" Margin="419,247,0,0" VerticalAlignment="Top" Width="145" Fill="#FFFFFDFD" Opacity="0.7"/>
        <materialDesign:RatingBar HorizontalAlignment="Left" Height="30" Margin="433,247,0,0" VerticalAlignment="Top" Width="117"/>
        <TextBlock HorizontalAlignment="Left" Height="43" Margin="319,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="186" Background="#FF770000" FontFamily="Old English Text MT" FontSize="26" Foreground="White" Padding="54,4,0,0"><Run Language="en-ie" Text="Search"/></TextBlock>
    </Grid>
</Window>
